{
  "name": "Terraform Labs",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/aws-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "docker pull localstack/localstack:latest",
  "postStartCommand": "bash .devcontainer/setup.sh",
  "postAttachCommand": "code WELCOME.md",
  "workspaceFolder": "/workspaces/prabhuthangavel-labs",
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [4566],
  "portsAttributes": {
    "4566": {
      "label": "LocalStack",
      "onAutoForward": "silent"
    }
  }
}
